use "@std/math" as math

pr("--- ViperLang Math Test ---")

pr("Pi     = ", math.pi())
pr("e      = ", math.euler())
pr("sin(0) = ", math.sin(0.0))
pr("cos(0) = ", math.cos(0.0))

v root = math.sqrt(16.0)
pr("sqrt(16) = ", root)

v power = math.pow(2.0, 3.0)
pr("pow(2, 3) = ", power)

v neg = 0 - 15.5
v val = math.abs(neg)
pr("abs(-15.5) = ", val)

pr("ceil(4.2)  = ", math.ceil(4.2))
pr("floor(4.8) = ", math.floor(4.8))

pr("Math Library Fully Functional! 🐍")
