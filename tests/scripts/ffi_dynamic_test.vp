// ffi_dynamic_test.vp
// Load the standard C math library (libm.so)
var libc = load_dl("libc.so.6")

var puts = libc.get_fn("puts", "s->i")
puts("Hello from Libc via True Dynamic FFI!")

var libm = load_dl("libm.so.6")

// Resolve the 'cos' function: double cos(double)
var cos = libm.get_fn("cos", "d->d")

var result = cos(0)
pr("Cos(0) = ", result)
