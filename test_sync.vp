v counter = 0

fn worker() {
    v k = 0
    m (k < 1000) {
        sync {
            v current = counter
            v temp = current + 1
            counter = temp
        }
        k = k + 1
    }
    ret 0
}

pr("Starting 10 concurrent threads...")

v t1 = spawn worker()
v t2 = spawn worker()
v t3 = spawn worker()
v t4 = spawn worker()
v t5 = spawn worker()
v t6 = spawn worker()
v t7 = spawn worker()
v t8 = spawn worker()
v t9 = spawn worker()
v t10 = spawn worker()

await t1
await t2
await t3
await t4
await t5
await t6
await t7
await t8
await t9
await t10

fn print_final() {
    pr("Final counter value (Expected 10000): ", counter)
}

print_final()
