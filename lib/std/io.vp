// ViperLang Standard IO Library (@std/io)
// Built using True Dynamic FFI bindings.


st File {
    handle
}

pub fn open(path, mode) {
    var libc = load_dl("libc.so.6")
    var _fopen = libc.get_fn("fopen", "s,s->p")
    var handle = _fopen(path, mode)
    // NOTE: In the future, we would check for NULL points here
    // but FFI pointer handling currently assumes strings or generic pointers.
    // For now, if handle is 0/null it will crash natively if used, which mimics C.
    
    var file_obj = File()
    file_obj.handle = handle
    ret file_obj
}

pub fn close(file) {
    var libc = load_dl("libc.so.6")
    var _fclose = libc.get_fn("fclose", "p->i")
    _fclose(file.handle)
}

pub fn write_text(file, text) {
    var libc = load_dl("libc.so.6")
    var _fputs = libc.get_fn("fputs", "s,p->i")
    _fputs(text, file.handle)
}

pub fn remove_file(path) {
    var libc = load_dl("libc.so.6")
    var _remove = libc.get_fn("remove", "s->i")
    _remove(path)
}
